<Page
    x:Class="WeatherPro.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Error / status banner -->
        <InfoBar
            Grid.Row="0"
            Severity="Warning"
            IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringToBoolConverter}}"
            Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

        <!-- Large current-conditions card -->
        <Border Grid.Row="1" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="24">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="{x:Bind ViewModel.LocationLabel, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <TextBlock FontSize="64" FontWeight="SemiBold"
                               Text="{x:Bind ViewModel.Current.TemperatureC, Mode=OneWay, Converter={StaticResource TemperatureConverter}, ConverterParameter='0'}" />
                    <TextBlock Text="{x:Bind ViewModel.Current.WeatherDescription, Mode=OneWay}" Opacity="0.7" />
                    <TextBlock Text="{x:Bind ViewModel.Current.FeelsLikeC, Mode=OneWay, Converter={StaticResource TemperatureConverter}, ConverterParameter='Feels like {0}'}" Opacity="0.7" />
                </StackPanel>

                <!-- Secondary metrics grid -->
                <GridView Grid.Column="1" ItemsSource="{x:Bind MetricTiles, Mode=OneWay}" SelectionMode="None" IsItemClickEnabled="False">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}" Width="140">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Label}" Opacity="0.6" FontSize="12" />
                                    <TextBlock Text="{Binding Value}" FontSize="18" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>
        </Border>

        <!-- Hourly strip -->
        <Border Grid.Row="2" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16">
            <ListView ItemsSource="{x:Bind ViewModel.Hourly, Mode=OneWay}" SelectionMode="None"
                      ScrollViewer.HorizontalScrollMode="Enabled" ScrollViewer.VerticalScrollMode="Disabled">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="16" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Spacing="4" Width="72" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Time}" HorizontalAlignment="Center" FontSize="12" Opacity="0.6" />
                            <TextBlock Text="{Binding TemperatureC}" HorizontalAlignment="Center" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding RainProbabilityPct}" HorizontalAlignment="Center" FontSize="12" Opacity="0.6" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <ProgressRing Grid.Row="0" Grid.RowSpan="3" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center" Width="48" Height="48" />
    </Grid>
</Page>
