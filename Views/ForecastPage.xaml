<Page
    x:Class="WeatherPro.Views.ForecastPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24">
        <InfoBar Severity="Warning" VerticalAlignment="Top"
                 IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringToBoolConverter}}"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

        <ListView ItemsSource="{x:Bind ViewModel.Days, Mode=OneWay}" SelectionMode="None" Margin="0,48,0,0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="16" Margin="0,4" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Date}" VerticalAlignment="Center" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{Binding WeatherCode}" VerticalAlignment="Center" Opacity="0.7" />
                            <TextBlock Grid.Column="2" Text="{Binding RainProbabilityPct}" VerticalAlignment="Center" Opacity="0.7" />
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding TempMinC}" Opacity="0.6" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding TempMaxC}" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Page>
