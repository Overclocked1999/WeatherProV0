<Window
    x:Class="WeatherPro.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <NavigationView
            x:Name="NavView"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            SelectionChanged="NavView_SelectionChanged"
            Loaded="NavView_Loaded">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Tag="dashboard" Icon="Home" />
                <NavigationViewItem Content="Forecast" Tag="forecast" Icon="CalendarDay" />
                <NavigationViewItem Content="Favorites" Tag="favorites" Icon="Favorite" />
                <NavigationViewItem Content="Settings" Tag="settings" Icon="Setting" />
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
